# AutoPhoto 后端环境变量配置
# 复制此文件为 .env，填入实际值后使用
# railway.app 控制台 → 你的项目 → Variables → 添加变量

# ============================================
# 虎皮椒支付（必需）
# ============================================
XUNHU_APP_ID=your_app_id_here
XUNHU_APP_SECRET=your_app_secret_here

# 支付成功后跳转地址（你的前端地址）
XUNHU_RETURN_URL=https://autophoto.store

# ============================================
# 邮件发送 - 方案A：Resend（强烈推荐！）
# Railway 美国服务器与 Resend 完全兼容
# 注册地址：https://resend.com（免费，100封/天）
# 注册完 → API Keys → Create API Key → 复制填入下面
# ============================================
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 发件人地址：
#   - 如果你没有验证自己的域名，用默认：onboarding@resend.dev
#   - 如果你已经在 Resend 验证了 autophoto.store 域名，填：noreply@autophoto.store
EMAIL_FROM=AutoPhoto <onboarding@resend.dev>

# ============================================
# 邮件发送 - 方案B：Gmail SMTP（备用）
# 如果你不用 Resend，可以用 Gmail 作为备用
# 步骤：Google账户 → 安全性 → 两步验证（开启）→ 应用专用密码 → 生成16位密码
# ⚠️  注意：不要填 QQ 邮箱！Railway 美国 IP 被 QQ SMTP 封锁！
# ============================================
# SMTP_PROVIDER=gmail
# SMTP_USER=tourinn@gmail.com
# SMTP_PASS=你的16位Gmail应用专用密码

# ============================================
# 管理通知（收到新订单时通知你）
# ============================================
ADMIN_EMAIL=tourinn@gmail.com

# ============================================
# Railway 部署（自动设置，无需手动修改）
# ============================================
# Railway 会自动设置 PORT 环境变量
# RAILWAY_STATIC_URL=your-app.railway.app
